# Anthropic credentials. Use the SSO flow from `claude` CLI for personal dev,
# or set ANTHROPIC_API_KEY for headless services.
ANTHROPIC_API_KEY=

# Where Micah operates. For Firefox work this is your mozilla-central checkout.
MICAH_CWD=/path/to/mozilla-central

# Master safety flag. Until set to 1, every external write (moz-phab submit,
# mach try, git/hg push, gh pr create, MCP write tools) is dry-run only and
# logged as "would have done X".
MICAH_WRITE_ENABLED=0

# Slack adapter (Bolt + Socket Mode).
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-
SLACK_SIGNING_SECRET=

# GitHub adapter (webhook server + Octokit).
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_PORT=8787

# Firefox Development MCP server (auto-mounted in Micah).
MOZ_MCP_URL=https://mcp-dev.moz.tools/mcp

# Matrix adapter (chat.mozilla.org).
MATRIX_HOMESERVER_URL=https://chat.mozilla.org
MATRIX_ACCESS_TOKEN=
MATRIX_DATA_DIR=./matrix-data
MATRIX_MENTION=@micah

# Session/thread memory persistence (default: ./logs/sessions.json).
MICAH_SESSIONS_PATH=

# Audit log path/toggle (default: ./logs/<sessionId>.jsonl, set to 0 to disable).
MICAH_AUDIT_LOG=
MICAH_AUDIT_PATH=
