{
  "name": "micah",
  "private": true,
  "version": "0.1.0",
  "description": "Micah: an AI engineer for the Firefox AI Pod.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
