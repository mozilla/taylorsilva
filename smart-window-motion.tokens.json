{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$name": "Smart Window Motion",
  "$description": "Motion design tokens for Firefox Smart Window. Three-tier architecture: base → semantic → component. Source of truth: ai-window-motion.css",

  "motion": {
    "$type": "group",
    "$description": "Smart Window motion system — all tokens for duration, easing, spring, stagger, opacity, choreography, translateY, and delight.",

    "duration": {
      "$type": "duration",
      "$description": "Eight duration tiers. Named by feel, not by size.",
      "instant": {
        "$value": "60ms",
        "$description": "Felt, not watched. Acknowledge, toggles, hover."
      },
      "quick": {
        "$value": "140ms",
        "$description": "Fast but visible. Small Arrive, Settle, Retreat."
      },
      "moderate": {
        "$value": "240ms",
        "$description": "The workhorse. Most Arrive, content transitions."
      },
      "gracious": {
        "$value": "300ms",
        "$description": "A half-beat more. Delight moments, ambient resolve."
      },
      "considered": {
        "$value": "360ms",
        "$description": "Deserves attention. Sidebar, mode shifts, alerts."
      },
      "deliberate": {
        "$value": "500ms",
        "$description": "Most intentional. Kill switch, first launch. Rare."
      },
      "breathe": {
        "$value": "3000ms",
        "$description": "Ambient cycle. Breathe state."
      },
      "pulse": {
        "$value": "2400ms",
        "$description": "Reduced-motion breathe. Still Alive, Just Quiet."
      }
    },

    "easing": {
      "$description": "Eight hand-tuned linear() curves, one per primitive feeling. No cubic-bezier in Smart Window except spring CSS approximations.",

      "arrive": {
        "$type": "cubicBezier",
        "$value": "linear(0, 0.002, 0.01 2.8%, 0.058 6.2%, 0.16 10.9%, 0.842 40.2%, 0.924 46.9%, 0.974 55.5%, 0.994 66.6%, 1 80.2%, 1)",
        "$description": "Confident entrance. ai-window, cards, undo bars. Genuine. 11 control points, default 240ms.",
        "$extensions": {
          "com.smartwindow.motion": {
            "controlPoints": 11,
            "trait": "Genuine",
            "defaultDuration": "240ms",
            "primitive": "Arrive",
            "meaning": "Something is here that wasn't"
          }
        }
      },
      "offer": {
        "$type": "cubicBezier",
        "$value": "linear(0, 0.001, 0.004 3.5%, 0.02 8%, 0.06 14%, 0.18 22%, 0.78 52%, 0.91 62%, 0.97 74%, 0.995 86%, 1)",
        "$description": "Tentative entrance. Ambient suggestions, unfinished work. Genuine + Playful. 11 points, default 288ms.",
        "$extensions": {
          "com.smartwindow.motion": {
            "controlPoints": 11,
            "trait": "Genuine + Playful",
            "defaultDuration": "288ms",
            "primitive": "Offer",
            "meaning": "Something the browser noticed"
          }
        }
      },
      "settle": {
        "$type": "cubicBezier",
        "$value": "linear(0, 0.004, 0.016 3.4%, 0.062 6.9%, 0.17 11.4%, 0.854 41.3%, 0.926 47.2%, 0.975 56%, 0.995 67.2%, 1 81%, 1)",
        "$description": "Content at rest. The exhale after motion. Genuine. 11 points, default 140ms.",
        "$extensions": {
          "com.smartwindow.motion": {
            "controlPoints": 11,
            "trait": "Genuine",
            "defaultDuration": "140ms",
            "primitive": "Settle",
            "meaning": "Things have landed"
          }
        }
      },
      "depart": {
        "$type": "cubicBezier",
        "$value": "linear(0, 0.45 10%, 0.75 30%, 0.94 60%, 1)",
        "$description": "Warm exit. Quick, done. Genuine. 5 points, default 140ms.",
        "$extensions": {
          "com.smartwindow.motion": {
            "controlPoints": 5,
            "trait": "Genuine",
            "defaultDuration": "140ms",
            "primitive": "Retreat",
            "meaning": "Something is leaving"
          }
        }
      },
      "breathe": {
        "$type": "cubicBezier",
        "$value": "linear(0, 0.008, 0.032 4.2%, 0.09 8.4%, 0.22 14%, 0.88 48%, 0.94 55%, 0.98 65%, 0.998 78%, 1)",
        "$description": "Ambient presence. chat-assistant-loader thinking. Playful. 10 points, default 3000ms.",
        "$extensions": {
          "com.smartwindow.motion": {
            "controlPoints": 10,
            "trait": "Playful",
            "defaultDuration": "3000ms",
            "primitive": "Breathe",
            "meaning": "The AI is present"
          }
        }
      },
      "act": {
        "$type": "cubicBezier",
        "$value": "linear(0, 0.005, 0.025 4%, 0.08 8%, 0.28 18%, 0.52 32%, 0.74 48%, 0.88 60%, 0.95 72%, 0.99 85%, 1)",
        "$description": "Purposeful execution. Agentic tab management. Fiery. 11 points, duration varies.",
        "$extensions": {
          "com.smartwindow.motion": {
            "controlPoints": 11,
            "trait": "Fiery",
            "defaultDuration": "varies",
            "primitive": "Flow",
            "meaning": "The AI is speaking"
          }
        }
      },
      "cross": {
        "$type": "cubicBezier",
        "$value": "linear(0, 0.001, 0.005 4%, 0.015 8%, 0.05 14%, 0.12 20%, 0.75 50%, 0.92 65%, 0.98 78%, 0.998 88%, 1)",
        "$description": "Boundary passage. Kill switch, mode shifts. Fiery. 11 points, default 360ms.",
        "$extensions": {
          "com.smartwindow.motion": {
            "controlPoints": 11,
            "trait": "Fiery",
            "defaultDuration": "360ms",
            "primitive": "Shift",
            "meaning": "A boundary is being crossed"
          }
        }
      },
      "delight": {
        "$type": "cubicBezier",
        "$value": "linear(0, 0.003, 0.012 4%, 0.05 10%, 0.14 18%, 0.50 40%, 0.86 62%, 0.95 74%, 0.988 84%, 0.998 92%, 1)",
        "$description": "One-shot magic. Luminance, wink, recovery. Playful. 11 points, default 300ms.",
        "$extensions": {
          "com.smartwindow.motion": {
            "controlPoints": 11,
            "trait": "Playful",
            "defaultDuration": "300ms",
            "primitive": "Delight",
            "meaning": "Ornamental moment layered on functional primitive"
          }
        }
      }
    },

    "spring": {
      "$description": "Three spring tiers for JS spring solver (SmartWindowMotion.sys.mjs). CSS cubic-bezier approximations included for fallback.",

      "light": {
        "$type": "group",
        "$description": "Chips, badges, toasts, @mention chips. 1–2% overshoot.",
        "stiffness": { "$type": "number", "$value": 480 },
        "damping": { "$type": "number", "$value": 35 },
        "css-approximation": {
          "$type": "cubicBezier",
          "$value": [0.22, 0.88, 0.35, 1.04],
          "$description": "CSS cubic-bezier fallback for --motion-spring-light"
        }
      },
      "medium": {
        "$type": "group",
        "$description": "ai-window sidebar, smartwindow-panel-list, undo bar. 2–3% overshoot.",
        "stiffness": { "$type": "number", "$value": 380 },
        "damping": { "$type": "number", "$value": 30 },
        "css-approximation": {
          "$type": "cubicBezier",
          "$value": [0.175, 0.885, 0.32, 1.08],
          "$description": "CSS cubic-bezier fallback for --motion-spring-medium"
        }
      },
      "heavy": {
        "$type": "group",
        "$description": "Response cards, evidence panels, canvas. 3–4% overshoot.",
        "stiffness": { "$type": "number", "$value": 280 },
        "damping": { "$type": "number", "$value": 26 },
        "css-approximation": {
          "$type": "cubicBezier",
          "$value": [0.165, 0.84, 0.28, 1.10],
          "$description": "CSS cubic-bezier fallback for --motion-spring-heavy"
        }
      }
    },

    "stagger": {
      "$description": "Six stagger types. Variance applied at runtime by SmartWindowMotion.sys.mjs. Reduced motion collapses all to 0ms.",

      "rhythm": {
        "$type": "duration",
        "$value": "70ms",
        "$description": "Lists, chips, cards, smartwindow-prompts, follow-up chips. ±12ms variance.",
        "$extensions": { "com.smartwindow.motion": { "variance": 12 } }
      },
      "ambient": {
        "$type": "duration",
        "$value": "100ms",
        "$description": "Ambient suggestions on new tab. Wider, unhurried. Vigilant posture. ±20ms variance.",
        "$extensions": { "com.smartwindow.motion": { "variance": 20 } }
      },
      "evidence": {
        "$type": "duration",
        "$value": "100ms",
        "$description": "Trust badges, source cascade, research synthesis sources. ±15ms variance.",
        "$extensions": { "com.smartwindow.motion": { "variance": 15 } }
      },
      "ceremony": {
        "$type": "duration",
        "$value": "120ms",
        "$description": "Welcome sequence, onboarding cards. Intentional reading pace. ±10ms variance.",
        "$extensions": { "com.smartwindow.motion": { "variance": 10 } }
      },
      "cascade": {
        "$type": "duration",
        "$value": "50ms",
        "$description": "Chrome transitions, tab bar reconfiguration. Fixed, no variance."
      },
      "action": {
        "$type": "duration",
        "$value": "40ms",
        "$description": "Sequential tab close, agentic checklist, multi-step execution. Fixed, no variance."
      }
    },

    "opacity": {
      "$description": "Opacity tokens for ambient, streaming, emphasis, and recency states.",

      "breathe-min": { "$type": "number", "$value": 0.55, "$description": "Breathe cycle trough. High contrast override: 0.45." },
      "stream-start": { "$type": "number", "$value": 0.0, "$description": "Streaming chunk initial opacity." },
      "dim": { "$type": "number", "$value": 0.45, "$description": "Dimmed/deemphasized. High contrast override: 0.35." },
      "emphasis-dip": { "$type": "number", "$value": 0.85, "$description": "Brief dip before emphasis. High contrast override: 0.75." },
      "vigilant-max": { "$type": "number", "$value": 0.5, "$description": "Vigilant posture ceiling. Never feels pressuring." },
      "vigilant-resolve": { "$type": "number", "$value": 0.85, "$description": "Vigilant → Attentive transition target." },
      "recency-1h": { "$type": "number", "$value": 0.5, "$description": "Ambient suggestion seen within 1 hour." },
      "recency-24h": { "$type": "number", "$value": 0.4, "$description": "Ambient suggestion seen within 24 hours." },
      "recency-7d": { "$type": "number", "$value": 0.35, "$description": "Ambient suggestion seen within 7 days." },
      "recency-old": { "$type": "number", "$value": 0.3, "$description": "Ambient suggestion older than 7 days." }
    },

    "translateY": {
      "$description": "Vertical displacement scale for entrance animations. Maximum 16px.",
      "small": { "$type": "dimension", "$value": "4px", "$description": "Icons, badges, labels." },
      "medium": { "$type": "dimension", "$value": "8px", "$description": "Cards, chips, messages, prompts." },
      "large": { "$type": "dimension", "$value": "12px", "$description": "Headings, panels." },
      "max": { "$type": "dimension", "$value": "16px", "$description": "Absolute maximum. Never exceeded." }
    },

    "posture": {
      "$description": "Four postures — multipliers applied to base tokens at runtime. The body language of the product.",

      "attentive": {
        "$type": "group",
        "$description": "Focused on you. Default posture. 1:1 with base tokens.",
        "duration-multiplier": { "$type": "number", "$value": 1.0 },
        "stagger-multiplier": { "$type": "number", "$value": 1.0 },
        "overshoot-multiplier": { "$type": "number", "$value": 1.0 },
        "opacity-max": { "$type": "number", "$value": 1.0 }
      },
      "active": {
        "$type": "group",
        "$description": "Working for you. Faster, snappier, more overshoot.",
        "duration-multiplier": { "$type": "number", "$value": 0.85 },
        "stagger-multiplier": { "$type": "number", "$value": 0.75 },
        "overshoot-multiplier": { "$type": "number", "$value": 1.3 },
        "opacity-max": { "$type": "number", "$value": 1.0 }
      },
      "ambient": {
        "$type": "group",
        "$description": "Resting in the room. Slower, no springs, reduced opacity.",
        "duration-multiplier": { "$type": "number", "$value": 1.4 },
        "stagger-multiplier": { "$type": "number", "$value": 1.0 },
        "overshoot-multiplier": { "$type": "number", "$value": 0 },
        "opacity-max": { "$type": "number", "$value": 0.7 }
      },
      "vigilant": {
        "$type": "group",
        "$description": "Noticing, not announcing. Visible but uninsistent. 0.5 opacity ceiling.",
        "duration-multiplier": { "$type": "number", "$value": 1.2 },
        "stagger-multiplier": { "$type": "number", "$value": 1.2 },
        "overshoot-multiplier": { "$type": "number", "$value": 0.6 },
        "opacity-max": { "$type": "number", "$value": 0.5 }
      }
    },

    "streaming": {
      "$description": "Semantic tokens for streaming text with confidence modulation.",

      "chunk-fade": { "$type": "duration", "$value": "450ms", "$description": "Per-chunk fade-in duration (normal confidence)." },
      "chunk-pace": { "$type": "duration", "$value": "80ms", "$description": "Delay between 2-word chunks (normal confidence)." },
      "chunk-variance": { "$type": "duration", "$value": "15ms", "$description": "Random variance on chunk pace." },
      "sentence-pause": { "$type": "duration", "$value": "55ms", "$description": "Extra pause after sentence-ending punctuation. Preserved in reduced motion." },
      "degrade-threshold": { "$type": "duration", "$value": "16ms", "$description": "Paint time threshold. Above this, degrade to per-sentence streaming." },
      "hedging-pace": { "$type": "duration", "$value": "58ms", "$description": "Chunk pace when confidence is hedging." },
      "hedging-fade": { "$type": "duration", "$value": "780ms", "$description": "Fade duration when confidence is hedging." },
      "uncertain-pace": { "$type": "duration", "$value": "70ms", "$description": "Chunk pace when confidence is uncertain." },
      "uncertain-fade": { "$type": "duration", "$value": "975ms", "$description": "Fade duration when confidence is uncertain." }
    },

    "choreography": {
      "$description": "Semantic timing tokens for sequenced multi-step animations.",

      "content-delay": { "$type": "duration", "$value": "50ms", "$description": "Content inside landed containers." },
      "content-delay-spring": { "$type": "duration", "$value": "200ms", "$description": "Content inside spring-animated panels." },
      "crossfade-out": { "$type": "duration", "$value": "120ms", "$description": "Outgoing content fade." },
      "crossfade-beat": { "$type": "duration", "$value": "60ms", "$description": "Stillness between crossfade out and in." },
      "crossfade-in": { "$type": "duration", "$value": "200ms", "$description": "Incoming content fade." },
      "completion-stillness": { "$type": "duration", "$value": "350ms", "$description": "Pause after AI finishes responding. Reduced motion: 200ms." },
      "completion-tools": { "$type": "duration", "$value": "280ms", "$description": "Tool row entrance after completion stillness." },
      "completion-input": { "$type": "duration", "$value": "180ms", "$description": "Input field reactivation after completion." }
    },

    "color": {
      "$description": "Trust and alert colors. Light/dark mode values reference Acorn color primitives.",

      "trust-local": {
        "$type": "color",
        "$value": "{color.green.50}",
        "$description": "On-device processing. Green-50 light / Green-30 dark.",
        "$extensions": {
          "com.smartwindow.motion": {
            "light": "#058B00",
            "dark": "#54B948"
          }
        }
      },
      "trust-mozilla": {
        "$type": "color",
        "$value": "{color.blue.50}",
        "$description": "Mozilla cloud processing. Blue-50 light / Blue-30 dark.",
        "$extensions": {
          "com.smartwindow.motion": {
            "light": "#0060DF",
            "dark": "#73A7F3"
          }
        }
      },
      "trust-thirdparty": {
        "$type": "color",
        "$value": "{color.orange.50}",
        "$description": "Third-party provider processing. Orange-50 light / Orange-30 dark.",
        "$extensions": {
          "com.smartwindow.motion": {
            "light": "#E66000",
            "dark": "#F9A36C"
          }
        }
      },
      "alert-error": {
        "$type": "color",
        "$value": "{color.red.50}",
        "$description": "Error state. Red-50 light / Red-30 dark.",
        "$extensions": {
          "com.smartwindow.motion": {
            "light": "#E22850",
            "dark": "#FF6A75"
          }
        }
      },
      "alert-caution": {
        "$type": "color",
        "$value": "{color.yellow.50}",
        "$description": "Caution state. Yellow-50 light / Yellow-30 dark.",
        "$extensions": {
          "com.smartwindow.motion": {
            "light": "#EA9E1E",
            "dark": "#F5C862"
          }
        }
      },
      "alert-commerce": {
        "$type": "color",
        "$value": "{color.orange.40}",
        "$description": "Commerce/payment context. Orange-40 light / Orange-20 dark.",
        "$extensions": {
          "com.smartwindow.motion": {
            "light": "#F08A00",
            "dark": "#FCBD8F"
          }
        }
      }
    },

    "delight": {
      "$description": "Tokens for seven moments of delight. They exist purely for feeling.",

      "luminance-lift": { "$type": "number", "$value": 0.09, "$description": "filter: brightness() boost on completion. Non-vestibular, preserved in reduced motion." },
      "wink-duration": { "$type": "duration", "$value": "120ms", "$description": "Prompt submission box-shadow pulse." },
      "sweep-duration": { "$type": "duration", "$value": "800ms", "$description": "Session recognition background sweep. Removed in reduced motion." },
      "ripple-duration": { "$type": "duration", "$value": "200ms", "$description": "First ambient suggestion ring. Removed in reduced motion." },
      "evidence-ripple-duration": { "$type": "duration", "$value": "180ms", "$description": "Evidence chip arrival ring. Removed in reduced motion." },
      "recovery-overshoot": { "$type": "number", "$value": 1.5, "$description": "Undo action spring overshoot multiplier. 1.5× base damping." }
    },

    "component-transitions": {
      "$description": "Pre-composed transition shorthand tokens for Acorn interactive states.",

      "tab": {
        "$type": "group",
        "$description": "Tab hover/focus/active transitions.",
        "properties": { "$type": "string", "$value": "background-color, border-color, opacity" },
        "duration": { "$type": "string", "$value": "instant, quick, moderate" },
        "easing": { "$type": "string", "$value": "arrive" }
      },
      "button": {
        "$type": "group",
        "$description": "Button hover/active transitions.",
        "properties": { "$type": "string", "$value": "background-color, border-color" },
        "duration": { "$type": "string", "$value": "instant" },
        "easing": { "$type": "string", "$value": "arrive" }
      },
      "card-shadow": {
        "$type": "group",
        "$description": "Card elevation shadow transition.",
        "properties": { "$type": "string", "$value": "box-shadow" },
        "duration": { "$type": "string", "$value": "quick" },
        "easing": { "$type": "string", "$value": "arrive" }
      },
      "scrim-arrive": {
        "$type": "group",
        "$description": "Scrim/overlay fade in.",
        "properties": { "$type": "string", "$value": "opacity" },
        "duration": { "$type": "string", "$value": "moderate" },
        "easing": { "$type": "string", "$value": "arrive" }
      },
      "scrim-retreat": {
        "$type": "group",
        "$description": "Scrim/overlay fade out.",
        "properties": { "$type": "string", "$value": "opacity" },
        "duration": { "$type": "string", "$value": "quick" },
        "easing": { "$type": "string", "$value": "depart" }
      }
    }
  }
}
